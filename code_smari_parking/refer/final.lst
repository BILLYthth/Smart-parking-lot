.................... // Display minutes as "Time: XXm" 
.................... void display_minutes(int min) { 
....................    lcd2_command(0x80); 
....................    lcd2_data('T'); 
....................    lcd2_data('i'); 
....................    lcd2_data('m'); 
....................    lcd2_data('e'); 
....................    lcd2_data(':'); 
....................    lcd2_data(' '); 
....................    lcd2_data((min / 10) + '0'); // Tens 
....................    lcd2_data((min % 10) + '0'); // Units 
....................    lcd2_data('m'); 
....................    lcd2_data(' '); // Clear any leftover char 
.................... } 
